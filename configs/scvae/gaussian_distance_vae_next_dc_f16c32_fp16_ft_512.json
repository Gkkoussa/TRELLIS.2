            },
            "ema_rate": [
                0.9999
            ],
            "fp16_mode": "inflat_all",
            "fp16_scale_growth": 0.001,
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 1.0,
                    "clip_percentile": 95
                }
            },
            "finetune_ckpt": {
                "encoder": "/nfs/turbo/coe-jjparkcv-medium/gpranav/objxl_4k/outputs/gaussian_distance_vae/ckpts/encoder_step0230000.pt",
                "decoder": "/nfs/turbo/coe-jjparkcv-medium/gpranav/objxl_4k/outputs/gaussian_distance_vae/ckpts/decoder_step0230000.pt"
            },
            "snapshot_batch_size": 1,
            "i_print": 1,
            "i_log": 10,
            "i_sample": 10000,
            "i_save": 10000,
            "lambda_kl": 5e-3,
            "loss_type": "l1",
            "lambda_render": 0.0
        }
    }
